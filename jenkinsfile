pipeline {
    agent any

    stages {

        stage('Checkout') {
            steps {
                echo 'Getting code from GitHub...'
                git branch: 'main',
                    url: 'https://github.com/YOUR_GITHUB_USERNAME/leafandpetals.git'
            }
        }

        stage('Build') {
            steps {
                echo 'Starting build containers...'
                sh 'docker compose -f docker-compose.jenkins.yml down --remove-orphans || true'
                sh 'docker compose -f docker-compose.jenkins.yml up -d'
            }
        }

        stage('Docker Push') {
            steps {
                script {
                    docker.withRegistry('https://index.docker.io/v1/', 'dockerhub-credentials') {
                        def img = docker.build("YOUR_DOCKERHUB_USERNAME/leafandpetals:${BUILD_NUMBER}")
                        img.push()
                        img.push('latest')
                    }
                }
            }
        }

        stage('Cleanup') {
            steps {
                echo 'Stopping build containers...'
                sh 'docker compose -f docker-compose.jenkins.yml down || true'
            }
        }
    }

    post {
        failure {
            sh 'docker compose -f docker-compose.jenkins.yml down || true'
        }
    }
}